# Spice Krewe — client-side integration keys (Vite prefix required for browser/Capacitor).
# Copy to `.env` and fill values. Never commit real secrets.

# Google Gemini (optional; Hire Flow AI summary)
VITE_GEMINI_API_KEY=

# Airtable REST API (optional; directory sync + brief submissions)
VITE_AIRTABLE_API_KEY=
VITE_AIRTABLE_BASE_ID=

# Table names (must match your base schema)
VITE_AIRTABLE_PROFESSIONALS_TABLE=Professionals
VITE_AIRTABLE_BRIEFS_TABLE=Briefs
# Optional Briefs fields (Phase 5): PrimaryInterestTalentIds, SourceTalentId, PostingTier (Single line text)

# Stripe (Phase 5 — client handshake only; implement POST handler separately)
VITE_STRIPE_PUBLIC_KEY=
# Same-origin API route (e.g. Vercel): https://spicekrewe.com/api/checkout → { "url": "..." }
VITE_STRIPE_CHECKOUT_ENDPOINT_URL=
